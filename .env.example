# ------ Bu dosyayı .env olarak kopyala ve doldur. .env asla commit edilmez. ------
# Yerelde `python -m src.pipeline --dry-run` çalıştırmak için HİÇBİRİ zorunlu değil
# (dry-run anahtarsız çalışır). Gerçek paylaşım için IG_* ve ANTHROPIC gerekir.

# --- Ideation (fikir + görsel prompt) — ÜCRETSİZ zincir ---
# Varsayılan zincir: gemini(ücretsiz) → pollinations(anahtarsız) → şablon. Hepsi $0.
GEMINI_API_KEY=                      # Google AI Studio ücretsiz katman anahtarı (önerilen)
ANTHROPIC_API_KEY=                   # opsiyonel, ücretli (chain'e "claude" eklenirse)
# IDEATE_PROVIDER=gemini             # tek sağlayıcıya zorlamak istersen

# --- Instagram Graph API (paylaşım) ---
IG_USER_ID=17841400000000000          # @kulupsapps profesyonel hesap ID'si
IG_ACCESS_TOKEN=IGAAxxxx              # uzun ömürlü token (60 gün)
IG_APP_ID=                            # token yenileme için (Meta app)
IG_APP_SECRET=                        # token yenileme için

# --- Görsel üretim sağlayıcıları (yalnızca kullanacağın için doldur) ---
PROVIDER=pollinations                 # pollinations | cloudflare | together | fal
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
TOGETHER_API_KEY=
FAL_KEY=

# --- Barındırma ---
# GitHub raw URL için: Actions'ta otomatik dolar; yerelde repo'nu ver (kullanıcı/repo).
REPO_SLUG=kullanici/cyberpunk-bot
# Cloudflare R2 kullanacaksan (host: r2):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=                        # ör. https://cdn.senindomainin.com

# kulups.com onay kuyruğu (igTaslakEkle) paylaşılan jetonu
IG_QUEUE_TOKEN=
